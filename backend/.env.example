# Required — get your free key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — only needed if you want job search functionality
# Get a free key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# RAPIDAPI_KEY=your_rapidapi_key_here

# PostgreSQL — required for JobPulse features (analytics, matching, challenges)
# Default: postgresql://postgres:postgres@localhost:5432/jobpulse
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobpulse
